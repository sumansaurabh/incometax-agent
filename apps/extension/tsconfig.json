{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@itx/action-dsl": ["../../packages/action-dsl/src"],
      "@itx/tax-schema": ["../../packages/tax-schema/dist/ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
